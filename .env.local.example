# Cloudinary — required for image fetching
# Find these in your Cloudinary dashboard under Settings > API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Used by next-cloudinary for CldImage rendering
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Site URL — used for sitemap and OG metadata
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Resend — used for contact form email delivery
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_api_key
# The email address that receives contact form submissions
CONTACT_TO_EMAIL=you@yourdomain.com
